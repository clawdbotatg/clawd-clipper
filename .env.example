# --- Episode resolution (mainnet read of the SlopComputer contract) ---
# Alchemy mainnet key. NEVER use a public RPC (see global rules).
# Grab a free key at https://dashboard.alchemy.com
ALCHEMY_API_KEY=

# --- Transcription (word-level timestamps via OpenAI whisper-1) ---
OPENAI_API_KEY=

# --- Clip selection + shareability ranking (Claude) ---
# Direct Anthropic is the default. Bankr's OpenClaw gateway is used as a
# fallback if ANTHROPIC_API_KEY is unset but BANKR_API_KEY is present.
ANTHROPIC_API_KEY=
BANKR_API_KEY=

# --- Optional overrides ---
# CLIPPER_ANTHROPIC_MODEL=claude-opus-4-7
# CLIPPER_BANKR_MODEL=claude-opus-4.7
# CLIPPER_JUDGE_MODEL=claude-opus-4-7   # adversarial re-rank; set cheaper to save credits
# CLIPPER_REFINE_MODEL=claude-opus-4-7  # context-aware caption correction; needs strong reasoning
# CLIPPER_TRANSCRIBE_MODEL=whisper-1
# IPFS_GATEWAY=https://media.slop.computer/ipfs
# SLOP_CONTRACT=0xf3ce3614fe8cd4294a0bf05d10cfda9d9cbc4886

# --- Caption burn-in (libass) ---
# libass-enabled ffmpeg for burning captions (brew install ffmpeg-full). Auto-
# detected at the path below; the everyday ffmpeg ops use plain `ffmpeg`.
# CLIPPER_FFMPEG_FULL_BIN=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
# CLIPPER_FFMPEG_BIN=ffmpeg
# Caption look — slop theme (ASS colours are &HAABBGGRR, reversed from #RRGGBB).
# CLIPPER_CAPTION_FONT=Menlo
# CLIPPER_CAPTION_SCALE=0.075          # font height as a fraction of video height (bigger = larger text)
# CLIPPER_CAPTION_BOX=1                # translucent band behind the line (lifts it off busy video); 0 to disable
# CLIPPER_CAPTION_BOX_COLOR=&H1A0A1F  # band fill — dark plum (&HBBGGRR)
# CLIPPER_CAPTION_BOX_ALPHA=&H55      # band transparency (&H00 opaque … &HFF clear)
# CLIPPER_CAPTION_BASE=&H00E04DD2     # resting word — purple #D24DE0
# CLIPPER_CAPTION_ACTIVE=&H00FFFFFF   # word being spoken — white
# CLIPPER_CAPTION_OUTLINE=&H00200818  # outline for legibility — near-black plum
# CLIPPER_CAPTION_GLOW=&H00D85FE0     # pink halo on the live word only
